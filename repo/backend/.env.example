# MeritTrack backend environment variables.
# Copy to .env and fill in all required values before starting the application.
# Never commit .env to version control.

# ── Database ────────────────────────────────────────────────────────────────────
# Required
DATABASE_URL=postgresql+psycopg2://merittrack:CHANGE_ME@db:5432/merittrack

# ── Security ────────────────────────────────────────────────────────────────────
# Required — must be at least 32 characters; used for internal HMAC operations.
SECRET_KEY=CHANGE_ME_MUST_BE_AT_LEAST_32_CHARS_LONG

# Directory containing KEK key files; active file is <KEK_PATH>/<KEK_CURRENT_VERSION>.key
KEK_PATH=/secrets/kek
KEK_CURRENT_VERSION=v1

# TLS certificate and private key paths (files must exist on host before docker compose up)
TLS_CERT_PATH=/certs/cert.pem
TLS_KEY_PATH=/certs/key.pem

# ── JWT ─────────────────────────────────────────────────────────────────────────
JWT_PRIVATE_KEY_PATH=/secrets/jwt_private.pem
JWT_PUBLIC_KEY_PATH=/secrets/jwt_public.pem
JWT_KEY_ID=mt-signing-1
JWT_ISSUER=merittrack
JWT_AUDIENCE=merittrack-app
# ACCESS_TOKEN_EXPIRE_MINUTES=15   # default: 15
# REFRESH_TOKEN_EXPIRE_DAYS=30     # default: 30

# ── Login throttle ──────────────────────────────────────────────────────────────
# LOGIN_THROTTLE_MAX_ATTEMPTS=5    # default: 5
# LOGIN_THROTTLE_WINDOW_MINUTES=15 # default: 15
# LOGIN_LOCKOUT_MINUTES=15         # default: 15

# ── Request signing ─────────────────────────────────────────────────────────────
# Set to true only if targeting browsers without non-extractable ECDSA support.
# WEBCRYPTO_FALLBACK_ENABLED=false # default: false

# ── Idempotency ─────────────────────────────────────────────────────────────────
# IDEMPOTENCY_KEY_TTL_HOURS=24     # default: 24

# ── Storage paths ───────────────────────────────────────────────────────────────
STORAGE_ROOT=/data/uploads
EXPORTS_ROOT=/data/exports
ACCESS_LOG_ROOT=/data/access-logs
FORECASTS_ROOT=/data/forecasts

# ── Frontend ────────────────────────────────────────────────────────────────────
FRONTEND_DIST_PATH=/app/frontend_dist

# ── Application ─────────────────────────────────────────────────────────────────
ENVIRONMENT=production

# ── Business rules (optional; feature flags take precedence at runtime) ─────────
# AUTO_CANCEL_MINUTES=30           # default: 30 — inactivity window before auto-cancel
# BARGAINING_WINDOW_HOURS=48       # default: 48 — max window for bargaining offers
# MAX_BARGAINING_OFFERS=3          # default: 3 — max candidate offers per order
# AFTER_SALES_WINDOW_DAYS=14       # default: 14 — days post-completion for after-sales requests
# NONCE_WINDOW_SECONDS=300         # default: 300 — request signing nonce TTL
# CLOCK_SKEW_TOLERANCE_SECONDS=30  # default: 30 — allowed clock skew for signature validation

# ── File upload limits ──────────────────────────────────────────────────────────
# MAX_UPLOAD_SIZE_BYTES=26214400   # default: 26214400 (25 MB)
# ALLOWED_MIME_TYPES=["application/pdf","image/jpeg","image/png"]
